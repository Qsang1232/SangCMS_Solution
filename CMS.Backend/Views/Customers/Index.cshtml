@using X.PagedList.Mvc.Core;
@using X.PagedList;
@model IPagedList<CMS.Data.Entities.Customer>

@{
    ViewData["Title"] = "Quản lý Khách hàng";
    Layout = "_LayoutAdmin";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold text-uppercase m-0"><i class="bi bi-person-lines-fill"></i> Danh sách khách hàng</h2>
        <a asp-action="Create" class="btn btn-success fw-bold shadow-sm">
            <i class="bi bi-plus-circle"></i> Thêm khách hàng
        </a>
    </div>
    <hr />

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width:60px" class="text-center">ID</th>
                        <th>Họ và Tên</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        <th>Địa chỉ</th>
                        <th style="width:180px" class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold text-secondary">@item.Id</td>
                                <td class="fw-bold text-dark">@item.FullName</td>
                                <td><a href="mailto:@item.Email" class="text-decoration-none">@item.Email</a></td>
                                <td>@(string.IsNullOrEmpty(item.Phone) ? "-" : item.Phone)</td>
                                <td class="text-truncate" style="max-width: 250px;" title="@item.Address">
                                    @(string.IsNullOrEmpty(item.Address) ? "-" : item.Address)
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning fw-bold text-dark me-1">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger fw-bold"
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa khách hàng này? Mọi đơn hàng liên quan có thể bị ảnh hưởng.')">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                Chưa có khách hàng nào trong hệ thống.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model != null && Model.PageCount > 1)
    {
        <div class="d-flex justify-content-end mt-4">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page = page }),
                new PagedListRenderOptions
                {
                    LiElementClasses = new string[] { "page-item" },
                    PageClasses = new string[] { "page-link" },
                    UlElementClasses = new string[] { "pagination", "mb-0", "pagination-sm", "shadow-sm" }
                })
        </div>
    }
</div>
