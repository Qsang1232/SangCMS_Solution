@model CMS.Data.Entities.User
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm thành viên - Nguyễn Quốc Sang";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white py-3">
            <h5 class="mb-0 fw-bold">THÊM THÀNH VIÊN HỆ THỐNG</h5>
            <small class="text-white-50">Sinh viên thực hiện: Nguyễn Quốc Sang - 2123110076</small>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">

                <div class="text-danger mb-3 font-weight-bold">
                    @Html.ValidationMessage("Username")
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên đăng nhập (Username):</label>
                        <input asp-for="Username" class="form-control" placeholder="Ví dụ: admin_thai" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Mật khẩu:</label>
                        <input asp-for="PasswordHash" type="password" class="form-control" placeholder="Nhập mật khẩu thô..." required />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Họ và Tên:</label>
                        <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Vai trò (Role):</label>
                        <select asp-for="Role" class="form-select" required>
                            <option value="">-- Chọn quyền hạn --</option>
                            <option value="Admin">Quản trị viên (Admin)</option>
                            <option value="Editor">Biên tập viên (Editor)</option>
                        </select>
                    </div>
                </div>

                <div class="mt-3 border-top pt-3 text-end">
                    <button type="submit" class="btn btn-primary px-4 me-2">Lưu thành viên</button>
                    <a asp-action="Index" class="btn btn-secondary px-4">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>