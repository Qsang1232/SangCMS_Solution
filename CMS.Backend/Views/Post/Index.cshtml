@model IEnumerable<CMS.Data.Entities.Post>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý danh sách bài viết - Nguyễn Quốc Sang";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="text-dark fw-bold mb-0">DANH SÁCH BÀI VIẾT</h2>
            <small class="text-muted">Sinh viên thực hiện: <strong>Nguyễn Quốc Sang</strong> - MSV: 2123110076</small>
        </div>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm bài viết mới
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail" style="height: 180px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-info text-dark align-self-start mb-2">@(item.Category != null ? item.Category.Name : "Chưa phân loại")</span>

                        <h5 class="card-title text-primary fw-bold text-truncate">@item.Title</h5>
                        <p class="card-text text-muted flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
                            @item.Content
                        </p>
                        <p class="text-muted small mb-3">Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")</p>

                        <div class="d-flex justify-content-between mt-auto border-top pt-2">
                            <a href="/Post/Details/@item.Id" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>

                            <div>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Sửa</a>

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Nguyễn Quốc Sang nhắc nhở: Chúng ta có chắc chắn muốn xóa bài viết này không?')">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>