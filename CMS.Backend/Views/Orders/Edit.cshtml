@model CMS.Data.Entities.Order
@{
    ViewData["Title"] = "Cập nhật đơn hàng";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0 fw-bold"><i class="fas fa-edit"></i> CẬP NHẬT ĐƠN HÀNG #@Model.Id</h4>
        </div>
        <div class="card-body bg-light">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- TRƯỜNG NÀY CỰC KỲ QUAN TRỌNG: Ẩn ID để hệ thống biết đang sửa đơn nào -->
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="OrderDate" />
                <input type="hidden" asp-for="CustomerId" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên người nhận <span class="text-danger">*</span></label>
                        <input asp-for="CustomerName" class="form-control" required />
                        <span asp-validation-for="CustomerName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                        <input asp-for="Phone" class="form-control" required />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                    <input asp-for="Address" class="form-control" required />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tổng tiền đơn hàng (VNĐ)</label>
                        <input asp-for="TotalAmount" class="form-control" type="number" />
                        <span asp-validation-for="TotalAmount" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold text-primary">Cập nhật trạng thái đơn</label>
                        <select asp-for="Status" class="form-select border-primary">
                            <option value="0">Chờ duyệt</option>
                            <option value="1">Đang giao hàng</option>
                            <option value="2">Đã hoàn thành</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Ghi chú đơn hàng</label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <div class="mt-4 border-top pt-3">
                    <button type="submit" class="btn btn-warning fw-bold px-4 text-dark">
                        <i class="fas fa-save"></i> Lưu thay đổi
                    </button>
                    <a asp-action="Index" class="btn btn-secondary px-4">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}