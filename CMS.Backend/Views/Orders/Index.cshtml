@model IEnumerable<CMS.Data.Entities.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary fw-bold text-uppercase mb-0">Quản lý đơn hàng</h2>
        <a asp-action="Create" class="btn btn-success fw-bold"><i class="fas fa-plus"></i> + Tạo đơn thủ công</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover table-bordered mb-0 text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Mã ĐH</th>
                        <th>Khách hàng</th>
                        <th>Số ĐT</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@item.Id</td>
                                <td>@item.CustomerName</td>
                                <td>@item.Phone</td>
                                <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-danger fw-bold">@item.TotalAmount.ToString("N0") đ</td>
                                <td>
                                    @if (item.Status == 0)
                                    {
                                        <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                    }
                                    else if (item.Status == 1)
                                    {
                                        <span class="badge bg-primary">Đang giao</span>
                                    }
                                    else if (item.Status == 2)
                                    {
                                        <span class="badge bg-success">Đã xong</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Xem</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-dark">Sửa</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa đơn hàng #@item.Id này?')">Xóa</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-muted py-4">Chưa có đơn hàng nào trong hệ thống.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>