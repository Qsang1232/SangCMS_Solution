@model CMS.Data.Entities.Order
@{
    ViewData["Title"] = "Thêm đơn hàng mới";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0 fw-bold"><i class="fas fa-plus-circle"></i> TẠO ĐƠN HÀNG MỚI</h4>
        </div>
        <div class="card-body bg-light">
            <form asp-action="Create">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên người nhận <span class="text-danger">*</span></label>
                        <input asp-for="CustomerName" class="form-control" required placeholder="Nhập họ tên" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                        <input asp-for="Phone" class="form-control" required placeholder="Nhập số điện thoại" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                    <input asp-for="Address" class="form-control" required placeholder="Nhập địa chỉ chi tiết" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tổng tiền đơn hàng (VNĐ)</label>
                        <input asp-for="TotalAmount" class="form-control" type="number" value="0" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Mã KH (Tùy chọn - Để trống nếu khách vãng lai)</label>
                        <!-- Đã bỏ required để tránh lỗi khóa ngoại -->
                        <input asp-for="CustomerId" class="form-control" type="number" placeholder="Nhập ID khách hàng nếu có" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Ghi chú đơn hàng</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Ghi chú thêm..."></textarea>
                </div>

                <div class="mt-4 border-top pt-3">
                    <button type="submit" class="btn btn-success px-4 fw-bold">Lưu đơn hàng</button>
                    <a asp-action="Index" class="btn btn-secondary px-4">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>