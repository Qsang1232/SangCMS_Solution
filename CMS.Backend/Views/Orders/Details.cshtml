@model CMS.Data.Entities.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0 fw-bold">CHI TIẾT ĐƠN HÀNG #@Model.Id</h4>
        </div>
        <div class="card-body">
            <div class="row mb-4 bg-light p-3 rounded">
                <div class="col-md-6">
                    <p><strong><i class="fas fa-user"></i> Khách hàng:</strong> @Model.CustomerName</p>
                    <p><strong><i class="fas fa-phone"></i> Số điện thoại:</strong> @Model.Phone</p>
                    <p><strong><i class="fas fa-map-marker-alt"></i> Địa chỉ:</strong> @Model.Address</p>
                </div>
                <div class="col-md-6">
                    <p><strong><i class="fas fa-calendar-alt"></i> Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p>
                        <strong><i class="fas fa-info-circle"></i> Trạng thái:</strong>
                        @if (Model.Status == 0)
                        {
                            <span class="badge bg-warning text-dark">Chờ duyệt</span>
                        }
                        else if (Model.Status == 1)
                        {
                            <span class="badge bg-primary">Đang giao</span>
                        }
                        else if (Model.Status == 2)
                        {
                            <span class="badge bg-success">Đã xong</span>
                        }
                    </p>
                    <p><strong><i class="fas fa-sticky-note"></i> Ghi chú:</strong> @(string.IsNullOrEmpty(Model.Notes) ? "Không có" : Model.Notes)</p>
                </div>
            </div>

            <h5 class="text-secondary fw-bold border-bottom pb-2">Danh sách sản phẩm trong đơn</h5>
            <table class="table table-bordered table-hover mt-2 text-center">
                <thead class="table-secondary">
                    <tr>
                        <th>Mã sản phẩm</th>
                        <th>Số lượng</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                    {
                        foreach (var detail in Model.OrderDetails)
                        {
                            <tr>
                                <td>@detail.ProductId</td>
                                <td>@detail.Quantity</td>
                                <td>@detail.Price.ToString("N0") VNĐ</td>
                                <td class="fw-bold text-danger">@((detail.Quantity * detail.Price).ToString("N0")) VNĐ</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-muted fst-italic py-3">Đơn hàng này chưa có chi tiết sản phẩm (Được tạo thủ công).</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="d-flex justify-content-end mb-4">
                <h4 class="fw-bold">TỔNG CỘNG: <span class="text-danger">@Model.TotalAmount.ToString("N0") VNĐ</span></h4>
            </div>

            <div class="mt-4 border-top pt-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning text-dark fw-bold px-4">Sửa đơn hàng</a>
                <a asp-action="Index" class="btn btn-secondary px-4">Quay lại danh sách</a>
            </div>
        </div>
    </div>
</div>