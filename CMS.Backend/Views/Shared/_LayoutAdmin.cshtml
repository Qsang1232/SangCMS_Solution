@{
    // Lấy tên Controller hiện tại để làm sáng menu Sidebar tương ứng
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SangCMS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
            body {
                background-color: #f8f9fa;
            }

            .sidebar {
                min-height: 100vh;
                background-color: #212529;
                color: white;
                box-shadow: 2px 0 5px rgba(0,0,0,0.1);
            }

                .sidebar a {
                    color: #adb5bd;
                    text-decoration: none;
                    display: block;
                    padding: 12px 20px;
                    transition: all 0.3s;
                    border-left: 4px solid transparent;
                }

                    .sidebar a:hover {
                        background-color: #343a40;
                        color: #fff;
                        border-left: 4px solid #0d6efd;
                    }

                .sidebar .active {
                    background-color: #0d6efd;
                    color: white;
                    border-left: 4px solid #fff;
                    font-weight: bold;
                }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- SIDEBAR CÓ TÍNH NĂNG ACTIVE TỰ ĐỘNG -->
            <nav class="col-md-3 col-lg-2 sidebar p-0 position-fixed">
                <div class="p-4 text-center border-bottom border-secondary bg-dark">
                    <h5 class="text-white fw-bold mb-0"><i class="bi bi-shield-lock"></i> SangCMS</h5>
                </div>
                <div class="mt-2">
                    <a asp-controller="Home" asp-action="Index" class="@(currentController == "Home" ? "active" : "")"><i class="bi bi-speedometer2 me-2"></i> Bảng điều khiển</a>
                    <a asp-controller="Category" asp-action="Index" class="@(currentController == "Category" ? "active" : "")"><i class="bi bi-grid me-2"></i> Danh mục</a>
                    <a asp-controller="Post" asp-action="Index" class="@(currentController == "Post" ? "active" : "")"><i class="bi bi-file-earmark-post me-2"></i> Bài viết</a>
                    <a asp-controller="User" asp-action="Index" class="@(currentController == "User" ? "active" : "")"><i class="bi bi-people me-2"></i> Thành viên</a>
                    <a asp-controller="Products" asp-action="Index" class="@(currentController == "Products" ? "active" : "")"><i class="bi bi-box-seam me-2"></i> Sản phẩm</a>
                    <a asp-controller="Orders" asp-action="Index" class="@(currentController == "Orders" ? "active" : "")"><i class="bi bi-cart-check me-2"></i> Đơn hàng</a>
                </div>
            </nav>

            <!-- KHU VỰC NỘI DUNG CHÍNH (Đẩy sang phải để không bị Sidebar đè lên) -->
            <main class="col-md-9 ms-sm-auto col-lg-10 p-0">
                <!-- NAVBAR TRÊN CÙNG -->
                <nav class="navbar navbar-expand-lg navbar-white bg-white shadow-sm mb-3 px-4 py-3">
                    <div class="container-fluid p-0">
                        <span class="navbar-text fw-bold text-uppercase text-secondary">
                            <i class="bi bi-layout-text-window-reverse"></i> @ViewData["Title"]
                        </span>

                        <div class="d-flex ms-auto align-items-center">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <div class="text-end me-3 border-end pe-3">
                                    <div class="fw-bold text-primary">
                                        <i class="bi bi-person-circle"></i> @User.FindFirst("FullName")?.Value
                                    </div>
                                    <span class="badge bg-success">
                                        @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                    </span>
                                </div>
                                <a class="btn btn-danger btn-sm fw-bold shadow-sm" asp-controller="Account" asp-action="Logout" onclick="return confirm('Bạn muốn đăng xuất khỏi hệ thống?')">
                                    <i class="bi bi-power"></i> Thoát
                                </a>
                            }
                        </div>
                    </div>
                </nav>

                <!-- KHU VỰC NỘI DUNG -->
                <div class="p-4">
                    <!-- Khu vực hiển thị thông báo thao tác thành công (TempData) -->
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                            <strong><i class="bi bi-check-circle-fill"></i> Thành công!</strong> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                            <strong><i class="bi bi-exclamation-triangle-fill"></i> Lỗi!</strong> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <!-- Ruột của từng trang sẽ đổ vào đây -->
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>