<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SangCMS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
        }

            .sidebar a {
                color: #adb5bd;
                text-decoration: none;
                display: block;
                padding: 10px 20px;
            }

                .sidebar a:hover {
                    background-color: #343a40;
                    color: white;
                }

            .sidebar .active {
                background-color: #0d6efd;
                color: white;
            }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 sidebar p-0">
                <div class="p-3 text-center border-bottom border-secondary">
                    <h4 class="text-white">SangCMS Admin</h4>
                </div>
                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2"></i> Bảng điều khiển</a>
                    <a asp-controller="Category" asp-action="Index"><i class="bi bi-grid"></i> Danh mục</a>
                    <a asp-controller="Post" asp-action="Index"><i class="bi bi-file-earmark-post"></i> Bài viết</a>
                    <a asp-controller="User" asp-action="Index"><i class="bi bi-people"></i> Quản lý Thành viên</a>
                    <a asp-controller="Products" asp-action="Index"><i class="bi bi-box-seam"></i> Sản phẩm</a>
                    <a asp-controller="Orders" asp-action="Index"><i class="bi bi-cart"></i> Đơn hàng</a>
                </div>
            </nav>

            <main class="col-md-9 col-lg-10 p-0">
                <nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm mb-3">
                    <div class="container-fluid">
                        <span class="navbar-text fw-bold">Xin chào Admin</span>
                        <div class="d-flex ms-auto align-items-center">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <div class="me-3 text-end">
                                    <div class="fw-bold small text-dark">
                                        <i class="bi bi-person-circle"></i> @User.FindFirst("FullName")?.Value
                                    </div>
                                    <span class="badge bg-dark" style="font-size: 0.7rem;">
                                        @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                    </span>
                                </div>
                                <a class="btn btn-outline-danger btn-sm" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                </a>
                            }
                        </div>
                    </div>
                </nav>

                <div class="p-4">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>